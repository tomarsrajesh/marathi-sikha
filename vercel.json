{
  "version": 2,
  "routes": [
    {
      "src": "/api/translate",
      "dest": "/api/translate.js"
    },
    {
      "src": "/icon-192.png",
      "dest": "/public/icon-192.png"
    },
    {
      "src": "/icon-512.png",
      "dest": "/public/icon-512.png"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "/public/apple-touch-icon.png"
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/public/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
